---
// src/components/LetterLayout.astro
const { frontmatter } = Astro.props;
const date = frontmatter?.date || "9th July 2026";
const ott = frontmatter?.ott || "";
---

<div class="letter-paper-wrapper">
  <div class="letter-paper-container">
    
    {/* Thông tin liên hệ */}
    <div class="letter-contact-info">
      <div>
        <span>+84 944928372</span> <span style="font-style: normal;">📞</span>
      </div>
      <div>
        <span>dinhlongtr.hcmcyu@gmail.com</span> <span style="font-style: normal;">✉</span>
      </div>
      <div>
        <span>trandinhlong.id.vn</span> <span style="font-style: normal;">🌐</span>
      </div>
    </div>

    {/* Ngày tháng */}
    <div class="letter-date">
      {date}
    </div>

    {/* Cấu trúc OTT */}
    {ott && (
      <div class="letter-ott">
        <span style="font-weight: bold;">OTT:</span> {ott}
      </div>
    )}

    {/* Nội dung bài viết thuần Markdown đổ vào slot này */}
    <div class="letter-content-area">
      <span class="letter-content-title">Bản tin:</span>
      <div class="letter-markdown-render">
        <slot />
      </div>
    </div>

    {/* Khối chữ ký và con dấu chồng lên nhau */}
    <div class="letter-signature-block">
      <div class="letter-kind-regards">Kind Regards,</div>
      <div class="letter-images-stack">
        <img src="../assets/ck.png" alt="Chữ ký" class="letter-img-ck" />
        <img src="../content/posts/cd1.png" alt="Con dấu" class="letter-img-cd" />
      </div>
      <div class="letter-signer-name">
        Trần Định Long
      </div>
    </div>

  </div>
</div>

<style is:global>
  /* Ép chết cấu trúc giấy trắng chữ đen bất chấp mọi chế độ Dark Mode của Astro */
  .letter-paper-wrapper {
    background-color: #ffffff !important;
    color: #000000 !important;
    padding: 10px;
    border-radius: 8px;
    margin: 10px auto;
    max-width: 770px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .letter-paper-container {
    font-family: Arial, sans-serif;
    max-width: 750px;
    margin: 0 auto;
    padding: 40px 20px;
    color: #000000 !important;
    line-height: 1.6;
    background-color: #ffffff !important;
  }

  .letter-contact-info {
    text-align: right;
    margin-bottom: 50px;
    font-size: 14px;
    color: #000000 !important;
  }
  .letter-contact-info div {
    margin-bottom: 8px;
    color: #000000 !important;
  }
  .letter-contact-info span {
    color: #000000 !important;
  }

  .letter-date {
    margin-bottom: 35px;
    font-weight: bold;
    font-size: 16px;
    color: #000000 !important;
  }

  .letter-ott {
    margin-bottom: 20px;
    font-size: 15px;
    color: #000000 !important;
  }
  .letter-ott span {
    color: #000000 !important;
  }

  .letter-content-area {
    margin-bottom: 120px;
    font-size: 15px;
    min-height: 200px;
    color: #000000 !important;
  }
  
  .letter-content-title {
    font-weight: bold;
    display: block;
    margin-bottom: 10px;
    color: #000000 !important;
  }

  /* CHÌA KHÓA FIX LỖI: Ép toàn bộ các thẻ sinh ra từ Markdown phải có màu đen */
  .letter-markdown-render,
  .letter-markdown-render * {
    color: #000000 !important;
    background-color: transparent !important;
  }
  
  .letter-markdown-render p,
  .letter-markdown-render li,
  .letter-markdown-render span,
  .letter-markdown-render strong,
  .letter-markdown-render em {
    color: #000000 !important;
  }

  /* Khối chữ ký */
  .letter-signature-block {
    position: relative;
    width: 300px;
    margin-top: 50px;
    color: #000000 !important;
  }
  
  .letter-kind-regards {
    font-size: 15px;
    margin-bottom: 5px;
    padding-left: 35px;
    color: #000000 !important;
  }

  .letter-images-stack {
    position: relative;
    height: 130px;
  }

  .letter-img-ck {
    position: absolute;
    left: 45px;
    top: 25px;
    width: 150px;
    height: auto;
    z-index: 1;
    pointer-events: none;
  }

  .letter-img-cd {
    position: absolute;
    left: 10px;
    top: 5px;
    width: 125px;
    height: auto;
    z-index: 2;
    pointer-events: none;
  }

  .letter-signer-name {
    font-weight: bold;
    font-size: 15px;
    margin-top: 5px;
    padding-left: 35px;
    color: #000000 !important;
  }
</style>
