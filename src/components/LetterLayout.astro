---
// src/components/LetterLayout.astro
import { Image } from 'astro:assets';

// Định vị chính xác file ảnh con dấu từ thư mục bài viết
import conDauImg from '../content/posts/cd1.png';

const { frontmatter } = Astro.props;
const date = frontmatter?.date || "9th July 2026";
const ott = frontmatter?.ott || "";
---

<div class="letter-paper-wrapper">
  <div class="letter-paper-container">
    
    {/* Thông tin liên hệ */}
    <div class="letter-contact-info">
      <div>
        <span>+84 944928372</span> <span style="font-style: normal;">📞</span>
      </div>
      <div>
        <span>dinhlongtr.hcmcyu@gmail.com</span> <span style="font-style: normal;">✉</span>
      </div>
      <div>
        <span>trandinhlong.id.vn</span> <span style="font-style: normal;">🌐</span>
      </div>
    </div>

    {/* Ngày tháng */}
    <div class="letter-date">
      {date}
    </div>

    {/* Cấu trúc OTT */}
    {ott && (
      <div class="letter-ott">
        <span style="font-weight: bold;">OTT:</span> {ott}
      </div>
    )}

    {/* Nội dung bài viết thuần Markdown */}
    <div class="letter-content-area">
    <div class="letter-markdown-render">
        <slot />
      </div>
    </div>

    {/* Khối chữ ký và con dấu SIÊU TO */}
    <div class="letter-signature-block">
      <div class="letter-kind-regards">Kind Regards,</div>
      <div class="letter-images-stack">
        {/* Chỉ hiển thị duy nhất ảnh con dấu đã phóng to */}
        <Image src={conDauImg} alt="Con dấu" class="letter-img-cd" />
      </div>
      <div class="letter-signer-name">
        Trần Đình Long
      </div>
    </div>

  </div>
</div>

<style is:global>
  .letter-paper-wrapper {
    background-color: #ffffff !important;
    color: #000000 !important;
    padding: 10px;
    border-radius: 8px;
    margin: 10px auto;
    max-width: 770px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .letter-paper-container {
    font-family: Arial, sans-serif;
    max-width: 750px;
    margin: 0 auto;
    padding: 40px 20px;
    color: #000000 !important;
    line-height: 1.6;
    background-color: #ffffff !important;
  }

  .letter-contact-info {
    text-align: right;
    margin-bottom: 50px;
    font-size: 14px;
    color: #000000 !important;
  }
  .letter-contact-info div {
    margin-bottom: 8px;
    color: #000000 !important;
  }

  .letter-date {
    margin-bottom: 35px;
    font-weight: bold;
    font-size: 16px;
    color: #000000 !important;
  }

  .letter-ott {
    margin-bottom: 20px;
    font-size: 15px;
    color: #000000 !important;
  }

  .letter-content-area {
    margin-bottom: 120px;
    font-size: 15px;
    min-height: 200px;
    color: #000000 !important;
  }
  
  .letter-content-title {
    font-weight: bold;
    display: block;
    margin-bottom: 10px;
    color: #000000 !important;
  }

  .letter-markdown-render,
  .letter-markdown-render * {
    color: #000000 !important;
    background-color: transparent !important;
  }
  
  .letter-markdown-render p,
  .letter-markdown-render li,
  .letter-markdown-render span,
  .letter-markdown-render strong {
    color: #000000 !important;
  }

  /* Khu vực chữ ký được nới rộng */
  .letter-signature-block {
    position: relative;
    width: 350px; /* Tăng chiều rộng khối nhận diện */
    margin-top: 50px;
    color: #000000 !important;
  }
  
  .letter-kind-regards {
    font-size: 15px;
    margin-bottom: 5px;
    padding-left: 35px;
    color: #000000 !important;
  }

  /* Tăng chiều cao vùng chứa ảnh lên 170px để dấu to không bị đè chữ dưới */
  .letter-images-stack {
    position: relative;
    height: 170px;
  }

  /* THAY ĐỔI: Kích thước con dấu được đẩy lên 185px (To, sắc nét) */
  .letter-img-cd {
    position: absolute !important;
    left: 15px !important;
    top: 5px !important;
    width: 185px !important; 
    height: auto !important;
    z-index: 2 !important;
    pointer-events: none;
  }

  .letter-signer-name {
    font-weight: bold;
    font-size: 15px;
    margin-top: 5px;
    padding-left: 35px;
    color: #000000 !important;
  }
</style>
